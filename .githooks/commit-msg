#!/bin/bash
# .githooks/commit-msg
#
# Enforces Conventional Commits format.
# Spec: https://www.conventionalcommits.org/en/v1.0.0/
#
# Valid types: feat, fix, docs, chore, refactor, test, style, ci, perf, build, revert
#
# Install: ./install-hooks.sh

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

# Skip merge commits, revert commits, fixup commits (git-generated)
if echo "$COMMIT_MSG" | grep -qE "^(Merge |Revert |fixup! |squash! )"; then
    exit 0
fi

# Allow WIP commits with a warning
if echo "$COMMIT_MSG" | grep -qiE "^WIP"; then
    echo -e "${YELLOW}⚠ WIP commit — skipping conventional commit validation${NC}"
    echo -e "${DIM}  Remember to squash/rebase before merging to main${NC}"
    exit 0
fi

VALID_TYPES="feat|fix|docs|chore|refactor|test|style|ci|perf|build|revert"
CONVENTIONAL_PATTERN="^(${VALID_TYPES})(\([a-zA-Z0-9_-]+\))?(!)?: .+"
SUBJECT=$(echo "$COMMIT_MSG" | head -1)

if ! echo "$SUBJECT" | grep -qE "$CONVENTIONAL_PATTERN"; then
    echo ""
    echo -e "${RED}✗ Commit message does not follow Conventional Commits format${NC}"
    echo ""
    echo -e "${DIM}Your message:${NC}"
    echo -e "  ${RED}${SUBJECT}${NC}"
    echo ""
    echo -e "${CYAN}Required format:${NC}"
    echo -e "  ${GREEN}<type>[optional scope][optional !]: <description>${NC}"
    echo ""
    echo -e "${CYAN}Valid types:${NC}"
    echo -e "  ${GREEN}feat${NC}     ${DIM}A new feature${NC}"
    echo -e "  ${GREEN}fix${NC}      ${DIM}A bug fix${NC}"
    echo -e "  ${GREEN}docs${NC}     ${DIM}Documentation only changes${NC}"
    echo -e "  ${GREEN}chore${NC}    ${DIM}Maintenance tasks${NC}"
    echo -e "  ${GREEN}refactor${NC} ${DIM}Code change with no feature/fix${NC}"
    echo -e "  ${GREEN}test${NC}     ${DIM}Adding or updating tests${NC}"
    echo -e "  ${GREEN}style${NC}    ${DIM}Formatting, whitespace (no logic change)${NC}"
    echo -e "  ${GREEN}ci${NC}       ${DIM}CI/CD configuration changes${NC}"
    echo -e "  ${GREEN}perf${NC}     ${DIM}Performance improvements${NC}"
    echo -e "  ${GREEN}build${NC}    ${DIM}Build system changes${NC}"
    echo -e "  ${GREEN}revert${NC}   ${DIM}Reverts a previous commit${NC}"
    echo ""
    echo -e "${CYAN}Examples:${NC}"
    echo -e "  ${DIM}feat: add schema-diff command${NC}"
    echo -e "  ${DIM}fix(restore): handle missing SQL file gracefully${NC}"
    echo -e "  ${DIM}docs: update README with Homebrew install instructions${NC}"
    echo -e "  ${DIM}ci: switch ShellCheck severity to error${NC}"
    echo ""
    echo -e "${YELLOW}To skip (emergency only): git commit --no-verify${NC}"
    echo ""
    exit 1
fi

# Advisory: description should start lowercase
DESCRIPTION=$(echo "$SUBJECT" | sed 's/^[^:]*: //')
if echo "$DESCRIPTION" | grep -qE "^[A-Z]"; then
    echo -e "${YELLOW}⚠ Style suggestion: description should start with lowercase${NC}"
    echo -e "  ${DIM}Consider: $(echo "$DESCRIPTION" | sed 's/^./\l&/')${NC}"
    echo ""
fi

# Advisory: subject line length
SUBJECT_LENGTH=${#SUBJECT}
if [ "$SUBJECT_LENGTH" -gt 72 ]; then
    echo -e "${YELLOW}⚠ Subject line is ${SUBJECT_LENGTH} chars (recommended max: 72)${NC}"
    echo ""
fi

echo -e "${GREEN}✓ Commit message format valid${NC}"
exit 0